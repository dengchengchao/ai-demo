{
  "name": "h5-jump",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "H5 跳一跳 game — Three.js + Vite",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "lint": "eslint . --ext .ts,.js",
    "lint:fix": "eslint . --ext .ts,.js --fix",
    "format": "prettier --write \"src/**/*.{ts,js,css,html}\" \"*.{json,md,html}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,css,html}\" \"*.{json,md,html}\""
  },
  "dependencies": {
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@types/three": "^0.160.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "prettier": "^3.2.5",
    "terser": "^5.27.0",
    "typescript": "^5.3.3",
    "vite": "^5.1.0"
  }
}
